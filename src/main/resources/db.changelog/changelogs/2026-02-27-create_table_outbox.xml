<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="2026-02-27-create_table_outbox" author="mr.pynzar.88@mail.ru">
        <createTable tableName="outbox">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="request_message_id" type="BIGINT">
                <constraints validateUnique="true" nullable="false"/>
            </column>
            <column name="payload_type" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
            <column name="payload" type="JSONB">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
            <column name="processed_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
            <column name="retry_count" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="trace_id" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="span_id" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <rollback>
            <delete tableName="outbox">
            </delete>
        </rollback>

    </changeSet>
</databaseChangeLog>